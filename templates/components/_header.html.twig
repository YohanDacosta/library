{# Header Component - Mobile and Desktop #}

{% set tutor = app.session.get('tutor') %}

{# Mobile Header #}
<header class="mobile-header" style="background: white; border-bottom: 1px solid #e5e7eb; padding: 12px 16px; align-items: center; justify-content: space-between;">
    <button onclick="toggleSidebar()" style="background: none; border: none; cursor: pointer; padding: 8px;">
        <svg style="width: 24px; height: 24px; color: #374151;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
    </button>
    <div style="display: flex; align-items: center; gap: 8px;">
        <div style="width: 32px; height: 32px; background: #9333ea; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" style="height: 18px; width: 18px; color: white;" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
            </svg>
        </div>
        <span style="font-size: 18px; font-weight: 700; color: #111827;">sp<span style="color: #9333ea;">!</span>k</span>
    </div>
    {% if tutor %}
    <div style="display: flex; align-items: center; gap: 8px;">
        <div style="width: 32px; height: 32px; border-radius: 50%; background: #f3e8ff; display: flex; align-items: center; justify-content: center;">
            <span style="color: #9333ea; font-weight: 500; font-size: 11px;">{{ tutor.firstName|slice(0, 1)|upper }}{{ tutor.lastName|slice(0, 1)|upper }}</span>
        </div>
        <a href="/logout" style="color: #6b7280; text-decoration: none; font-size: 12px;" title="Cerrar sesión">
            <svg xmlns="http://www.w3.org/2000/svg" style="height: 20px; width: 20px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
        </a>
    </div>
    {% endif %}
</header>

{# Desktop Header #}
<header class="desktop-header" style="background: white; border-bottom: 1px solid #e5e7eb; padding: 16px 32px; height: 73px; box-sizing: border-box;">
    {% if tutor %}
    <div style="display: flex; align-items: center; justify-content: flex-end; gap: 16px; height: 100%;">
        {# User Profile #}
        <div style="display: flex; align-items: center; gap: 12px; padding-left: 24px; border-left: 1px solid #e5e7eb;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: #f3e8ff; display: flex; align-items: center; justify-content: center;">
                <span style="color: #9333ea; font-weight: 500; font-size: 14px;">{{ tutor.firstName|slice(0, 1)|upper }}{{ tutor.lastName|slice(0, 1)|upper }}</span>
            </div>
            <div style="text-align: left;">
                <p style="font-size: 14px; font-weight: 500; color: #111827; margin: 0;">{{ tutor.firstName }} {{ tutor.lastName }}</p>
                <p style="font-size: 12px; color: #6b7280; margin: 0;">Tutor</p>
            </div>
            <a href="/logout" style="color: #6b7280; text-decoration: none; padding: 8px; margin-left: 8px; display: flex; align-items: center; gap: 6px; font-size: 13px; border-radius: 6px; transition: background-color 0.2s;" title="Cerrar sesión" onmouseover="this.style.backgroundColor='#f3f4f6'" onmouseout="this.style.backgroundColor='transparent'">
                <svg xmlns="http://www.w3.org/2000/svg" style="height: 18px; width: 18px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                <span>Salir</span>
            </a>
        </div>
    </div>
    {% endif %}
</header>
