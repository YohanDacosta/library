{% if students is empty %}
    <div style="padding: 32px; text-align: center;">
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; border-radius: 50%; background: #f3f4f6; margin-bottom: 16px;">
            <svg style="height: 32px; width: 32px; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
        </div>
        <p style="font-size: 14px; font-weight: 500; color: #111827; margin: 0;">No se encontraron estudiantes</p>
        <p style="font-size: 12px; color: #6b7280; margin-top: 4px;">Intenta con otro término de búsqueda</p>
    </div>
{% else %}
    <style>
        .student-search-results-table { display: none; }
        .student-search-results-cards { display: block; }

        @media (min-width: 768px) {
            .student-search-results-table { display: block; }
            .student-search-results-cards { display: none; }
        }
    </style>

    <div style="padding: 8px 0;">
        {# Header con contador #}
        <div style="padding: 12px 16px; background: linear-gradient(to right, #f5f3ff, #eff6ff); border-bottom: 1px solid #e0e7ff;">
            <p style="font-size: 12px; font-weight: 600; color: #4f46e5; margin: 0;">
                <span style="display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border-radius: 50%; background: #4f46e5; color: white; font-size: 11px; margin-right: 8px;">
                    {{ students|length }}
                </span>
                Estudiante{{ students|length > 1 ? 's' : '' }} encontrado{{ students|length > 1 ? 's' : '' }}
            </p>
        </div>

        {# Desktop: Table layout #}
        <div class="student-search-results-table">
            {# Table header #}
            <div style="display: grid; grid-template-columns: 48px 1fr 80px 1fr 100px; gap: 12px; padding: 12px 16px; background: #fafafa; border-bottom: 1px solid #e5e7eb; font-size: 11px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em;">
                <span></span>
                <span>Nombre</span>
                <span>Curso</span>
                <span>Escuela</span>
                <span>Fecha Registro</span>
            </div>

            {# Table rows #}
            <div>
                {% for student in students %}
                    {# Get initials #}
                    {% set initials = student.firstName|slice(0, 1)|upper ~ student.lastName|slice(0, 1)|upper %}

                    {# Determine avatar color based on first letter #}
                    {% set firstLetter = student.firstName|slice(0, 1)|upper %}
                    {% if firstLetter in ['A', 'B', 'C', 'D', 'E'] %}
                        {% set avatarBg = '#9333ea' %}
                    {% elseif firstLetter in ['F', 'G', 'H', 'I', 'J'] %}
                        {% set avatarBg = '#3b82f6' %}
                    {% elseif firstLetter in ['K', 'L', 'M', 'N', 'O'] %}
                        {% set avatarBg = '#10b981' %}
                    {% elseif firstLetter in ['P', 'Q', 'R', 'S', 'T'] %}
                        {% set avatarBg = '#f59e0b' %}
                    {% else %}
                        {% set avatarBg = '#ec4899' %}
                    {% endif %}

                    <a href="#" style="display: grid; grid-template-columns: 48px 1fr 80px 1fr 100px; gap: 12px; padding: 12px 16px; text-decoration: none; color: inherit; border-bottom: 1px solid #f3f4f6; align-items: center; transition: background 0.15s;"
                       onmouseover="this.style.background='#faf5ff'"
                       onmouseout="this.style.background='transparent'">
                        {# Avatar #}
                        <div style="width: 40px; height: 40px; border-radius: 50%; background: {{ avatarBg }}; display: flex; align-items: center; justify-content: center;">
                            <span style="color: white; font-weight: 600; font-size: 13px;">{{ initials }}</span>
                        </div>

                        {# Full Name #}
                        <span style="font-size: 13px; font-weight: 500; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {{ student.firstName }} {{ student.lastName }}
                        </span>

                        {# Course Badge #}
                        <span style="display: inline-flex; align-items: center; justify-content: center; padding: 2px 10px; background: #f3e8ff; color: #9333ea; font-size: 12px; font-weight: 500; border-radius: 9999px; width: fit-content;">
                            {{ student.course.name }}
                        </span>

                        {# School #}
                        <span style="font-size: 13px; color: #374151; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {{ student.school.name }}
                        </span>

                        {# Registration Date #}
                        <span style="font-size: 12px; color: #374151;">
                            {{ student.createdAt|date('d M, Y') }}
                        </span>
                    </a>
                {% endfor %}
            </div>
        </div>

        {# Mobile: Card layout #}
        <div class="student-search-results-cards">
            {% for student in students %}
                {# Get initials #}
                {% set initials = student.firstName|slice(0, 1)|upper ~ student.lastName|slice(0, 1)|upper %}

                {# Determine avatar color based on first letter #}
                {% set firstLetter = student.firstName|slice(0, 1)|upper %}
                {% if firstLetter in ['A', 'B', 'C', 'D', 'E'] %}
                    {% set avatarBg = '#9333ea' %}
                {% elseif firstLetter in ['F', 'G', 'H', 'I', 'J'] %}
                    {% set avatarBg = '#3b82f6' %}
                {% elseif firstLetter in ['K', 'L', 'M', 'N', 'O'] %}
                    {% set avatarBg = '#10b981' %}
                {% elseif firstLetter in ['P', 'Q', 'R', 'S', 'T'] %}
                    {% set avatarBg = '#f59e0b' %}
                {% else %}
                    {% set avatarBg = '#ec4899' %}
                {% endif %}

                <a href="#" style="display: flex; gap: 12px; padding: 12px 16px; text-decoration: none; color: inherit; border-bottom: 1px solid #f3f4f6; align-items: flex-start;"
                   onmouseover="this.style.background='#faf5ff'"
                   onmouseout="this.style.background='transparent'">
                    {# Avatar #}
                    <div style="width: 44px; height: 44px; border-radius: 50%; background: {{ avatarBg }}; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <span style="color: white; font-weight: 600; font-size: 14px;">{{ initials }}</span>
                    </div>

                    {# Student info #}
                    <div style="flex: 1; min-width: 0;">
                        <h4 style="font-size: 14px; font-weight: 500; color: #111827; margin: 0 0 4px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {{ student.firstName }} {{ student.lastName }}
                        </h4>
                        <p style="font-size: 13px; color: #6b7280; margin: 0 0 4px 0;">
                            Curso: <span style="background: #f3e8ff; color: #9333ea; padding: 2px 8px; border-radius: 9999px; font-size: 11px; font-weight: 500;">{{ student.course.name }}</span>
                        </p>
                        <p style="font-size: 12px; color: #9ca3af; margin: 0 0 2px 0;">
                            {{ student.school.name }}
                        </p>
                        <p style="font-size: 11px; color: #9ca3af; margin: 0;">
                            {{ student.createdAt|date('d M, Y') }}
                        </p>
                    </div>

                    {# Arrow #}
                    <svg style="width: 16px; height: 16px; color: #9ca3af; flex-shrink: 0; margin-top: 4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            {% endfor %}
        </div>
    </div>
{% endif %}
