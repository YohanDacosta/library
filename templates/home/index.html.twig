{% extends 'layouts/app.html.twig' %}

{% set activePage = 'home' %}

{% block title %}Library - Books{% endblock %}

{% block page_styles %}
<style>
    .book-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .search-dropdown { left: 0; right: 0; transform: none; min-width: auto; width: auto; margin: 8px 0 0 0; }
    .filter-buttons { flex-wrap: wrap; justify-content: center; }

    /* Tablet (768px+) */
    @media (min-width: 768px) {
        .book-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
        .search-dropdown { left: 50%; right: auto; transform: translateX(-50%); min-width: 700px; width: max-content; }
        .filter-buttons { justify-content: flex-end; }
    }

    /* Desktop (1024px+) */
    @media (min-width: 1024px) {
        .book-grid { grid-template-columns: repeat(5, 1fr); }
    }

    /* Large Desktop (1280px+) */
    @media (min-width: 1280px) {
        .book-grid { grid-template-columns: repeat(6, 1fr); gap: 24px; }
    }

    /* Modal styles */
    .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.5);
    }
    .modal-overlay.open {
        display: flex;
    }

    /* Book Cart styles */
    .book-cart {
        position: fixed;
        right: 24px;
        top: 50%;
        transform: translateY(-50%);
        width: 320px;
        max-height: 70vh;
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
        z-index: 40;
        flex-direction: column;
        display: none;
    }

    /* Mobile: Cart as bottom sheet */
    @media (max-width: 1023px) {
        .book-cart {
            right: 16px;
            left: 16px;
            bottom: 16px;
            top: auto;
            transform: none;
            width: auto;
            max-height: 50vh;
        }
    }

    /* Book card clickable styles */
    .book-card-clickable {
        cursor: pointer;
        transition: transform 0.15s;
    }
    .book-card-clickable:hover {
        transform: scale(1.02);
    }
    .book-card-unavailable {
        opacity: 0.5;
        cursor: default;
    }
</style>
{% endblock %}

{% block main_content %}
<div data-controller="book-cart"
     {% if tutors is defined %}
     data-tutors="{{ tutors|map(t => {id: t.id, firstName: t.firstName, lastName: t.lastName})|json_encode|e('html_attr') }}"
     {% endif %}>
    {# Page Title #}
    <div style="display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 24px;">
        <h1 class="page-title" style="font-family: Georgia, serif; text-align: center; color: #111827; margin: 0;">
            Todos os livros
        </h1>
    </div>

    {# Search and Filters #}
    <div style="max-width: 896px; margin: 0 auto 24px auto;">
        {# Search Bar #}
        <div
            {{ stimulus_controller('search-book', {url: path('app_home')}) }}
            style="position: relative; margin-bottom: 16px;"
        >
            <div style="display: flex; align-items: center; background: white; border-radius: 9999px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); border: 1px solid #e5e7eb; padding: 10px 20px;">
                <svg xmlns="http://www.w3.org/2000/svg" style="height: 20px; width: 20px; color: #9ca3af; margin-right: 12px; flex-shrink: 0;" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                </svg>
                <input
                    data-search-book-target="filter"
                    data-action="search-book#handleSearch"
                    style="flex: 1; outline: none; color: #374151; background: transparent; border: none; font-size: 16px; min-width: 0;"
                    type="search"
                    name="q"
                    value="{{ searchTerm }}"
                    placeholder="Busque por livro, autor..."
                >
            </div>

            {# Search Results Dropdown #}
            <div
                data-search-book-target="result"
                class="hidden search-dropdown"
                style="position: absolute; top: 100%; background: white; border-radius: 12px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04); max-height: 400px; overflow-y: auto; overflow-x: hidden; z-index: 50;"
            ></div>
        </div>

        {# Filter Buttons #}
        <div class="filter-buttons" style="display: flex; gap: 8px;">
            <button type="button" style="display: flex; align-items: center; gap: 6px; padding: 8px 12px; background: white; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13px; color: #374151; cursor: pointer; white-space: nowrap;">
                Filtrar por categoria
                <svg xmlns="http://www.w3.org/2000/svg" style="height: 14px; width: 14px;" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </button>
            <button type="button" style="display: flex; align-items: center; gap: 6px; padding: 8px 12px; background: white; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13px; color: #374151; cursor: pointer; white-space: nowrap;">
                Mais recentes
                <svg xmlns="http://www.w3.org/2000/svg" style="height: 14px; width: 14px;" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </button>
        </div>
    </div>

    {# Book Grid #}
    <div class="book-grid" style="display: grid;">
        {% for book in books %}
            {% set isAvailable = book.status.value == 'available' %}
            {# Status badge colors #}
            {% if book.status.value == 'available' %}
                {% set statusBg = '#dcfce7' %}
                {% set statusColor = '#166534' %}
                {% set statusText = 'Disponible' %}
            {% elseif book.status.value == 'loaned' %}
                {% set statusBg = '#dbeafe' %}
                {% set statusColor = '#1e40af' %}
                {% set statusText = 'Prestado' %}
            {% elseif book.status.value == 'reserved' %}
                {% set statusBg = '#fef3c7' %}
                {% set statusColor = '#92400e' %}
                {% set statusText = 'Reservado' %}
            {% elseif book.status.value == 'repaired' %}
                {% set statusBg = '#f3e8ff' %}
                {% set statusColor = '#7c3aed' %}
                {% set statusText = 'En reparación' %}
            {% else %}
                {% set statusBg = '#fee2e2' %}
                {% set statusColor = '#991b1b' %}
                {% set statusText = 'Perdido' %}
            {% endif %}

            <div class="{{ isAvailable ? 'book-card-clickable' : 'book-card-unavailable' }}"
                 {% if isAvailable %}
                 data-action="click->book-cart#addBook"
                 data-book-cart-id-param="{{ book.id }}"
                 data-book-cart-title-param="{{ book.title }}"
                 data-book-cart-author-param="{{ book.author }}"
                 data-book-cart-code-param="{{ book.code }}"
                 {% endif %}>
                {# Book Cover Placeholder #}
                <div style="aspect-ratio: 3/4; background: #e5e7eb; border-radius: 8px; margin-bottom: 8px; display: flex; align-items: center; justify-content: center;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="height: 36px; width: 36px; color: #9ca3af;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                </div>
                {# Book Info #}
                <h3 style="font-size: 13px; font-weight: 500; color: #111827; margin: 0 0 4px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ book.title }}</h3>
                <p style="font-size: 11px; color: #6b7280; margin: 0 0 6px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ book.author }}</p>
                {# Status Badge #}
                <span style="display: inline-block; padding: 2px 8px; background: {{ statusBg }}; color: {{ statusColor }}; font-size: 10px; font-weight: 500; border-radius: 9999px;">
                    {{ statusText }}
                </span>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if books.haveToPaginate %}
        <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid #e5e7eb; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 8px;">
            {# Previous Arrow #}
            {% if books.hasPreviousPage %}
                <a href="{{ path('app_home', {'page': books.previousPage}) }}"
                   style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; border-radius: 4px;"
                   onmouseover="this.style.background='#f3f4f6'"
                   onmouseout="this.style.background='transparent'">
                    <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
            {% else %}
                <span style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #d1d5db;">
                    <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </span>
            {% endif %}

            {# Page Numbers #}
            {% set currentPage = books.currentPage %}
            {% set totalPages = books.nbPages %}

            {# Always show first page #}
            {% if currentPage > 3 %}
                <a href="{{ path('app_home', {'page': 1}) }}"
                   style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; font-size: 14px; border-radius: 4px;"
                   onmouseover="this.style.background='#f3f4f6'"
                   onmouseout="this.style.background='transparent'">1</a>
                {% if currentPage > 4 %}
                    <span style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #6b7280; font-size: 14px;">...</span>
                {% endif %}
            {% endif %}

            {# Pages around current #}
            {% for page in max(1, currentPage - 2)..min(totalPages, currentPage + 2) %}
                {% if page == currentPage %}
                    <span style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: #9333ea; color: white; font-size: 14px; font-weight: 500; border-radius: 6px;">{{ page }}</span>
                {% else %}
                    <a href="{{ path('app_home', {'page': page}) }}"
                       style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; font-size: 14px; border-radius: 4px;"
                       onmouseover="this.style.background='#f3f4f6'"
                       onmouseout="this.style.background='transparent'">{{ page }}</a>
                {% endif %}
            {% endfor %}

            {# Always show last page #}
            {% if currentPage < totalPages - 2 %}
                {% if currentPage < totalPages - 3 %}
                    <span style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #6b7280; font-size: 14px;">...</span>
                {% endif %}
                <a href="{{ path('app_home', {'page': totalPages}) }}"
                   style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; font-size: 14px; border-radius: 4px;"
                   onmouseover="this.style.background='#f3f4f6'"
                   onmouseout="this.style.background='transparent'">{{ totalPages }}</a>
            {% endif %}

            {# Next Arrow #}
            {% if books.hasNextPage %}
                <a href="{{ path('app_home', {'page': books.nextPage}) }}"
                   style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; border-radius: 4px;"
                   onmouseover="this.style.background='#f3f4f6'"
                   onmouseout="this.style.background='transparent'">
                    <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            {% else %}
                <span style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #d1d5db;">
                    <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </span>
            {% endif %}
        </div>
    {% endif %}

    {# Book Cart (Floating) #}
    <div class="book-cart" data-book-cart-target="cart">
        {# Header #}
        <div style="padding: 16px 20px; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: space-between;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <svg style="width: 20px; height: 20px; color: #9333ea;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
                <span style="font-size: 15px; font-weight: 600; color: #111827;">Nuevo Préstamo</span>
            </div>
            <span data-book-cart-target="cartCount" style="display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; background: #9333ea; color: white; font-size: 12px; font-weight: 600; border-radius: 50%;">0</span>
        </div>

        {# Tutor Selection #}
        <div style="padding: 12px 16px; border-bottom: 1px solid #f3f4f6;">
            <label style="display: block; font-size: 12px; font-weight: 500; color: #6b7280; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">
                Tutor
            </label>

            {# Selected Tutor Display #}
            <div data-book-cart-target="selectedTutor" style="display: none;"></div>

            {# Tutor Search #}
            <div data-tutor-search-container style="position: relative;">
                <div style="display: flex; align-items: center; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 8px 12px;">
                    <svg style="width: 16px; height: 16px; color: #9ca3af; margin-right: 8px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input
                        type="text"
                        data-book-cart-target="tutorSearch"
                        data-action="focus->book-cart#onTutorSearchFocus input->book-cart#onTutorSearchInput"
                        placeholder="Buscar tutor..."
                        style="flex: 1; border: none; background: transparent; outline: none; font-size: 13px; color: #374151; min-width: 0;"
                    >
                </div>

                {# Tutor Dropdown #}
                <div data-book-cart-target="tutorDropdown"
                     style="display: none; position: absolute; top: 100%; left: 0; right: 0; margin-top: 4px; background: white; border: 1px solid #e5e7eb; border-radius: 8px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); max-height: 200px; overflow-y: auto; z-index: 10;">
                    <div data-book-cart-target="tutorList">
                        {# Tutor list populated via JS #}
                    </div>
                </div>
            </div>
        </div>

        {# Books Label #}
        <div style="padding: 12px 16px 0 16px;">
            <label style="display: block; font-size: 12px; font-weight: 500; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em;">
                Libros seleccionados
            </label>
        </div>

        {# Cart Items #}
        <div data-book-cart-target="cartItems" style="flex: 1; overflow-y: auto; padding: 8px 16px 16px 16px; display: flex; flex-direction: column; gap: 8px;">
            {# Items se agregan via JS #}
        </div>

        {# Footer with Create Button #}
        <div style="padding: 16px; border-top: 1px solid #e5e7eb;">
            <button type="button"
                    data-book-cart-target="createBtn"
                    data-action="click->book-cart#openLoanModal"
                    disabled
                    style="width: 100%; padding: 12px 16px; background: #9333ea; color: white; border: none; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;"
                    onmouseover="if(!this.disabled) this.style.background='#7c3aed'"
                    onmouseout="this.style.background='#9333ea'">
                <svg style="width: 18px; height: 18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Crear Préstamo
            </button>
        </div>
    </div>

    {# Modal Create Loan #}
    <div
        id="createLoanModal"
        data-controller="loan-form"
        data-loan-form-students-url-value="/get-students-by-tutor-id"
        data-loan-form-create-url-value="/loan/create"
        class="modal-overlay"
    >
        {# Modal Content #}
        <div
            style="background: white; border-radius: 12px; width: 90%; max-width: 500px; max-height: 90vh; overflow-y: auto; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);"
            data-action="click->modal#stopPropagation"
        >
            {# Header #}
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; border-bottom: 1px solid #e5e7eb;">
                <h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0;">
                    Crear Préstamo
                </h2>
                <button
                    type="button"
                    data-controller="modal"
                    data-action="click->modal#close"
                    style="background: none; border: none; cursor: pointer; padding: 4px; border-radius: 4px;"
                    onmouseover="this.style.background='#f3f4f6'"
                    onmouseout="this.style.background='transparent'"
                >
                    <svg style="width: 24px; height: 24px; color: #6b7280;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            {# Form Body #}
            <form data-action="submit->loan-form#submit" style="padding: 24px; display: flex; flex-direction: column; gap: 20px;">
                {# Error Messages #}
                <div data-loan-form-target="errorMessage"
                     style="display: none; padding: 12px 16px; background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; color: #dc2626; font-size: 13px;">
                </div>

                {# Tutor Select #}
                <div>
                    <label style="display: block; font-size: 14px; font-weight: 500; color: #374151; margin-bottom: 6px;">
                        Tutor
                    </label>
                    <select
                        data-loan-form-target="tutor"
                        data-action="change->loan-form#filterStudents"
                        style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; color: #111827; background: white; cursor: pointer;"
                    >
                        <option value="">Seleccionar tutor...</option>
                        {% if tutors is defined %}
                            {% for tutor in tutors %}
                                <option value="{{ tutor.id }}">{{ tutor.firstName }} {{ tutor.lastName }}</option>
                            {% endfor %}
                        {% endif %}
                    </select>
                </div>

                {# Student Select #}
                <div>
                    <label style="display: block; font-size: 14px; font-weight: 500; color: #374151; margin-bottom: 6px;">
                        Estudiante
                    </label>
                    <select
                        data-loan-form-target="student"
                        style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; color: #111827; background: white; cursor: pointer;"
                        disabled
                    >
                        <option value="">Primero seleccione un tutor...</option>
                    </select>
                </div>

                {# Selected Books (read-only from cart) #}
                <div>
                    <label style="display: block; font-size: 14px; font-weight: 500; color: #374151; margin-bottom: 6px;">
                        Libros a prestar
                    </label>
                    <div data-book-cart-target="booksList"
                         style="display: flex; flex-direction: column; gap: 8px; max-height: 120px; overflow-y: auto; padding: 4px 0;">
                        {# Se llena dinámicamente desde el carrito #}
                    </div>
                </div>

                {# Date Fields Row #}
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    {# Loan Date #}
                    <div>
                        <label style="display: block; font-size: 14px; font-weight: 500; color: #374151; margin-bottom: 6px;">
                            Fecha Préstamo
                        </label>
                        <input
                            type="date"
                            data-loan-form-target="loanDate"
                            data-action="change->loan-form#updateReturnDate"
                            style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; color: #111827; box-sizing: border-box;"
                        >
                    </div>

                    {# Return Date #}
                    <div>
                        <label style="display: block; font-size: 14px; font-weight: 500; color: #374151; margin-bottom: 6px;">
                            Fecha Devolución
                        </label>
                        <input
                            type="date"
                            data-loan-form-target="returnDate"
                            style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; color: #111827; box-sizing: border-box;"
                        >
                    </div>
                </div>
            </form>

            {# Footer #}
            <div style="display: flex; justify-content: flex-end; gap: 12px; padding: 16px 24px; border-top: 1px solid #e5e7eb; background: #fafafa; border-radius: 0 0 12px 12px;">
                <button
                    type="button"
                    data-controller="modal"
                    data-action="click->modal#close"
                    style="padding: 10px 20px; background: white; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; font-weight: 500; color: #374151; cursor: pointer;"
                    onmouseover="this.style.background='#f3f4f6'"
                    onmouseout="this.style.background='white'"
                >
                    Cancelar
                </button>
                <button
                    type="button"
                    data-loan-form-target="submitBtn"
                    data-action="click->loan-form#submit"
                    style="padding: 10px 20px; background: #9333ea; border: none; border-radius: 8px; font-size: 14px; font-weight: 500; color: white; cursor: pointer;"
                    onmouseover="this.style.background='#7c3aed'"
                    onmouseout="this.style.background='#9333ea'"
                >
                    Crear Préstamo
                </button>
            </div>
        </div>
    </div>
</div>{# End book-cart controller wrapper #}
{% endblock %}
