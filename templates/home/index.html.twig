{% extends 'layouts/app.html.twig' %}

{% set activePage = 'home' %}

{% block title %}Library - Books{% endblock %}

{% block page_styles %}
<style>
    .book-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .search-dropdown { left: 0; right: 0; transform: none; min-width: auto; width: auto; margin: 8px 0 0 0; }
    .filter-buttons { flex-wrap: wrap; justify-content: center; }

    /* Tablet (768px+) */
    @media (min-width: 768px) {
        .book-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
        .search-dropdown { left: 50%; right: auto; transform: translateX(-50%); min-width: 700px; width: max-content; }
        .filter-buttons { justify-content: flex-end; }
    }

    /* Desktop (1024px+) */
    @media (min-width: 1024px) {
        .book-grid { grid-template-columns: repeat(5, 1fr); }
    }

    /* Large Desktop (1280px+) */
    @media (min-width: 1280px) {
        .book-grid { grid-template-columns: repeat(6, 1fr); gap: 24px; }
    }
</style>
{% endblock %}

{% block main_content %}
    {# Page Title #}
    <h1 class="page-title" style="font-family: Georgia, serif; text-align: center; color: #111827; margin-top: 0;">Todos os livros</h1>

    {# Search and Filters #}
    <div style="max-width: 896px; margin: 0 auto 24px auto;">
        {# Search Bar #}
        <div
            {{ stimulus_controller('search-book', {url: path('app_home')}) }}
            style="position: relative; margin-bottom: 16px;"
        >
            <div style="display: flex; align-items: center; background: white; border-radius: 9999px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); border: 1px solid #e5e7eb; padding: 10px 20px;">
                <svg xmlns="http://www.w3.org/2000/svg" style="height: 20px; width: 20px; color: #9ca3af; margin-right: 12px; flex-shrink: 0;" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                </svg>
                <input
                    data-search-book-target="filter"
                    data-action="search-book#handleSearch"
                    style="flex: 1; outline: none; color: #374151; background: transparent; border: none; font-size: 16px; min-width: 0;"
                    type="search"
                    name="q"
                    value="{{ searchTerm }}"
                    placeholder="Busque por livro, autor..."
                >
            </div>

            {# Search Results Dropdown #}
            <div
                data-search-book-target="result"
                class="hidden search-dropdown"
                style="position: absolute; top: 100%; background: white; border-radius: 12px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04); max-height: 400px; overflow-y: auto; overflow-x: hidden; z-index: 50;"
            ></div>
        </div>

        {# Filter Buttons #}
        <div class="filter-buttons" style="display: flex; gap: 8px;">
            <button type="button" style="display: flex; align-items: center; gap: 6px; padding: 8px 12px; background: white; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13px; color: #374151; cursor: pointer; white-space: nowrap;">
                Filtrar por categoria
                <svg xmlns="http://www.w3.org/2000/svg" style="height: 14px; width: 14px;" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </button>
            <button type="button" style="display: flex; align-items: center; gap: 6px; padding: 8px 12px; background: white; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13px; color: #374151; cursor: pointer; white-space: nowrap;">
                Mais recentes
                <svg xmlns="http://www.w3.org/2000/svg" style="height: 14px; width: 14px;" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </button>
        </div>
    </div>

    {# Book Grid #}
    <div class="book-grid" style="display: grid;">
        {% for book in books %}
            <div>
                {# Book Cover Placeholder #}
                <div style="aspect-ratio: 3/4; background: #e5e7eb; border-radius: 8px; margin-bottom: 8px; display: flex; align-items: center; justify-content: center;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="height: 36px; width: 36px; color: #9ca3af;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                </div>
                {# Book Info #}
                <h3 style="font-size: 13px; font-weight: 500; color: #111827; margin: 0 0 4px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ book.title }}</h3>
                <p style="font-size: 11px; color: #6b7280; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ book.author }}</p>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if books.haveToPaginate %}
        <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid #e5e7eb; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 8px;">
            {# Previous Arrow #}
            {% if books.hasPreviousPage %}
                <a href="{{ path('app_home', {'page': books.previousPage}) }}"
                   style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; border-radius: 4px;"
                   onmouseover="this.style.background='#f3f4f6'"
                   onmouseout="this.style.background='transparent'">
                    <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
            {% else %}
                <span style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #d1d5db;">
                    <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </span>
            {% endif %}

            {# Page Numbers #}
            {% set currentPage = books.currentPage %}
            {% set totalPages = books.nbPages %}

            {# Always show first page #}
            {% if currentPage > 3 %}
                <a href="{{ path('app_home', {'page': 1}) }}"
                   style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; font-size: 14px; border-radius: 4px;"
                   onmouseover="this.style.background='#f3f4f6'"
                   onmouseout="this.style.background='transparent'">1</a>
                {% if currentPage > 4 %}
                    <span style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #6b7280; font-size: 14px;">...</span>
                {% endif %}
            {% endif %}

            {# Pages around current #}
            {% for page in max(1, currentPage - 2)..min(totalPages, currentPage + 2) %}
                {% if page == currentPage %}
                    <span style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: #9333ea; color: white; font-size: 14px; font-weight: 500; border-radius: 6px;">{{ page }}</span>
                {% else %}
                    <a href="{{ path('app_home', {'page': page}) }}"
                       style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; font-size: 14px; border-radius: 4px;"
                       onmouseover="this.style.background='#f3f4f6'"
                       onmouseout="this.style.background='transparent'">{{ page }}</a>
                {% endif %}
            {% endfor %}

            {# Always show last page #}
            {% if currentPage < totalPages - 2 %}
                {% if currentPage < totalPages - 3 %}
                    <span style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #6b7280; font-size: 14px;">...</span>
                {% endif %}
                <a href="{{ path('app_home', {'page': totalPages}) }}"
                   style="min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; font-size: 14px; border-radius: 4px;"
                   onmouseover="this.style.background='#f3f4f6'"
                   onmouseout="this.style.background='transparent'">{{ totalPages }}</a>
            {% endif %}

            {# Next Arrow #}
            {% if books.hasNextPage %}
                <a href="{{ path('app_home', {'page': books.nextPage}) }}"
                   style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #374151; text-decoration: none; border-radius: 4px;"
                   onmouseover="this.style.background='#f3f4f6'"
                   onmouseout="this.style.background='transparent'">
                    <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            {% else %}
                <span style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #d1d5db;">
                    <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </span>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
